#!/bin/sh

version_number="4.15.0"

# UI

external_menu() {
    [ "$use_external_menu" = "1" ] && rofi "$1" -sort -dmenu -i -width 1500 -p "$2" "$3"
    [ "$use_external_menu" = "2" ] && dmenu -l 20 -p "$2"
}

launcher() {
    [ "$use_external_menu" = "0" ] && [ -z "$1" ] && set -- "+m" "$2"
    [ "$use_external_menu" = "0" ] && fzf "$1" --reverse --cycle --prompt "$2"
    [ "$use_external_menu" = "1" ] && external_menu "$1" "$2" "$external_menu_args"
    [ "$use_external_menu" = "2" ] && external_menu "$1" "$2"
}

nth() {
    stdin=$(cat -)
    [ -z "$stdin" ] && return 1
    line_count="$(printf "%s\n" "$stdin" | wc -l | tr -d "[:space:]")"
    [ "$line_count" -eq 1 ] && printf "%s" "$stdin" | cut -f2,3 && return 0
    prompt="$1"
    multi_flag=""
    [ $# -ne 1 ] && shift && multi_flag="$1"
    line=$(printf "%s" "$stdin" | cut -f1,3 | tr '\t' ' ' | launcher "$multi_flag" "$prompt" | cut -d " " -f 1)
    line_start=$(printf "%s" "$line" | head -n1)
    line_end=$(printf "%s" "$line" | tail -n1)
    [ -n "$line" ] || exit 1
    if [ "$line_start" = "$line_end" ]; then
        printf "%s" "$stdin" | grep -E '^'"${line}"'($|[[:space:]])' | cut -f2,3 || exit 1
    else
        printf "%s" "$stdin" | sed -n '/^'"${line_start}"'$/,/^'"${line_end}$"'/p' || exit 1
    fi
}

die() {
    printf "\33[2K\r\033[1;31m%s\033[0m\n" "$*" >&2
    exit 1
}

help_info() {
    printf "
    Usage:
    %s [options] [query]
    %s [query] [options]
    %s [options] [query] [options]

    Options:
      -c, --continue
        Continue watching from history
      -d, --download
        Download the video instead of playing it
      -D, --delete
        Delete history
      -l, --logview
        Show logs
      -s, --syncplay
        Use Syncplay to watch with friends
      -S, --select-nth
        Select nth entry
      -q, --quality
        Specify the video quality
      -v, --vlc
        Use VLC to play the video
      -V, --version
        Show the version of the script
      -h, --help
        Show this help message and exit
      -e, --episode, -r, --range
        Specify the number of episodes to watch
      --dub
        Play dubbed version
      --rofi
        Use rofi instead of fzf for the interactive menu
      --dmenu
        Use dmenu instead of fzf for the interactive menu
      --skip
        Skip opening/ending automatically (integrated, mpv only; installs a small mpv lua plugin on first use)
      --no-detach
        Don't detach the player (useful for in-terminal playback, mpv only)
      --exit-after-play
        Exit the player, and return the player exit code (useful for non interactive scenarios, mpv only)
      --skip-title <title|mal_id>
        Override anime detection for skip: a MAL id (numeric) or a title to look up on MyAnimeList
      -N, --nextep-countdown
        Display a countdown to the next episode
      -U, --update
        Update the script
    Some example usages:
      %s -q 720p banana fish
      %s --skip --skip-title \"one piece\" -S 2 one piece
      %s -d -e 2 cyberpunk edgerunners
      %s --vlc cyberpunk edgerunners -q 1080p -e 4
      %s blue lock -e 5-6
      %s -e \"5 6\" blue lock
    \n" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}"
    exit 0
}

version_info() {
    printf "%s\n" "$version_number"
    exit 0
}

update_script() {
    printf "[branch:%s] Checking for Update..\n" "$branch"
    update="$(curl --fail-with-body -sL -A "$agent" "https://raw.githubusercontent.com/nicolagalassi/ani-cli-it/$branch/ani-cli")" || die "[branch:$branch] Connection error: $update"
    printf '%s' "$update" | grep -q "^version_number" || die "[branch:$branch] Invalid Response."
    update="$(printf '%s\n' "$update" | diff -u "$0" -)"
    if [ -z "$update" ]; then
        printf "[branch:%s] Script is up to date :)\n" "$branch"
    else
        if printf '%s\n' "$update" | patch "$0" -; then
            printf "[branch:%s] Script has been updated\n" "$branch"
        else
            die "[branch:$branch] Can't update for some reason!"
        fi
    fi
    exit 0
}

# non-blocking update check: prints a notice from cache, refreshes the cache in the
# background at most once a day. Never slows startup, never fails the run.
check_update_notice() {
    [ "$update_check" = "1" ] || return 0
    command -v curl >/dev/null || return 0
    _uc_cache="$hist_dir/latest_version"
    _uc_url="https://raw.githubusercontent.com/nicolagalassi/ani-cli-it/$branch/ani-cli"

    # refresh cache in background if missing or older than 24h
    if [ ! -f "$_uc_cache" ] || [ -n "$(find "$_uc_cache" -mtime +1 2>/dev/null)" ]; then
        (
            _remote="$(curl --fail -sL -A "$agent" "$_uc_url" 2>/dev/null |
                sed -n 's/^version_number="\([^"]*\)".*/\1/p' | head -1)"
            [ -n "$_remote" ] && printf '%s\n' "$_remote" >"$_uc_cache"
        ) >/dev/null 2>&1 &
    fi

    # show a notice using whatever is cached (from a previous run)
    [ -f "$_uc_cache" ] || return 0
    _latest="$(cat "$_uc_cache" 2>/dev/null)"
    [ -n "$_latest" ] || return 0
    # notify only if the cached remote version is strictly newer than ours
    if [ "$_latest" != "$version_number" ] &&
        [ "$(printf '%s\n%s\n' "$version_number" "$_latest" | sort -V | tail -1)" = "$_latest" ]; then
        printf "\033[1;33mAggiornamento disponibile: %s -> %s. Esegui '%s -U' per aggiornare.\033[0m\n" \
            "$version_number" "$_latest" "${0##*/}" >&2
    fi
}

# checks if dependencies are present
dep_ch() {
    for dep; do
        command -v "${dep%% *}" >/dev/null || die "Program \"${dep%% *}\" not found. Please install it."
    done
}

where_iina() {
    [ -e "/Applications/IINA.app/Contents/MacOS/iina-cli" ] && echo "/Applications/IINA.app/Contents/MacOS/iina-cli" && return 0
    printf "%s" "iina" && return 0
}

where_mpv() {
    command -v "flatpak" >/dev/null && flatpak info io.mpv.Mpv >/dev/null 2>&1 && printf "%s" "flatpak_mpv" && return 0
    printf "%s" "mpv" && return 0
}

cleanup() {
    [ "$player_function" = "android_mpv" ] && : >"/storage/emulated/0/mpv/mpv.config.mp4"
    printf "\033[0m"        # clears colors
    rm -f "${histfile}.new" # remove temp logfile
}

# SCRAPING

select_quality() {
    # animeworld exposes a single direct mp4 per episode; picks the only link and sets $episode
    case "$1" in
        best) result=$(printf "%s" "$links" | head -n1) ;;
        worst) result=$(printf "%s" "$links" | tail -n1) ;;
        *) result=$(printf "%s" "$links" | grep -m 1 "$1") ;;
    esac
    [ -z "$result" ] && result=$(printf "%s" "$links" | head -n1)
    # direct mp4 host needs no referrer
    unset refr_flag
    episode=$(printf "%s" "$result" | cut -d'>' -f2)
}

# resolves the direct mp4 url for $id (slug) episode $ep_no into $episode
get_episode_url() {
    # cache the play page across episodes of the same anime (ranges refetch nothing)
    if [ "$cached_play_id" != "$id" ]; then
        cached_play_html="$(curl -sL -A "$agent" "https://${animeworld_base}/play/$id")"
        cached_play_id="$id"
    fi

    # map the requested episode number to its data-id token from the episode list
    ep_token="$(printf '%s' "$cached_play_html" |
        grep -oE '<a [^>]*data-episode-num="'"$ep_no"'"[^>]*>' |
        grep -oE 'data-id="[A-Za-z0-9_-]+"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')"

    if [ -n "$ep_token" ]; then
        # the episode info api returns the direct mp4 url in "grabber"
        grabber="$(curl -s -A "$agent" "https://${animeworld_base}/api/episode/info?id=${ep_token}&alt=0" |
            sed -nE 's|.*"grabber":"([^"]*)".*|\1|p' | sed 's|\\/|/|g')"
        # fall back to the alternative server if the primary one is empty
        [ -z "$grabber" ] && grabber="$(curl -s -A "$agent" "https://${animeworld_base}/api/episode/info?id=${ep_token}&alt=1" |
            sed -nE 's|.*"grabber":"([^"]*)".*|\1|p' | sed 's|\\/|/|g')"
        [ -n "$grabber" ] && links="default >$grabber" || links=""
    else
        links=""
    fi
    printf "\033[1;32m%s\033[0m Links Fetched\n" "AnimeWorld" 1>&2

    select_quality "$quality"
    if printf "%s" "$ep_list" | grep -q "^$ep_no$"; then
        [ -z "$episode" ] && die "Episode is released, but no valid sources!"
    else
        [ -z "$episode" ] && die "Episode not released!"
    fi
}

# --- integrated ani-skip (no external dependency) ---

# mpv lua plugin that reads aniskip-* script-opts and seeks past OP/ED
skip_lua_path="${XDG_CONFIG_HOME:-$HOME/.config}/mpv/scripts/anicli-skip.lua"

install_skip_lua() {
    [ -f "$skip_lua_path" ] && return 0
    mkdir -p "${skip_lua_path%/*}" 2>/dev/null || return 1
    cat >"$skip_lua_path" <<'SKIP_LUA'
-- anicli-skip: auto-skip OP/ED using aniskip-* script-opts (bundled by ani-cli-it)
local mp = require('mp')
local mpv_options = require('mp.options')
local options = { op_start = 0, op_end = 0, ed_start = 0, ed_end = 0,
    toggle = false, toggle_key = "T", offset = 0 }
mpv_options.read_options(options, "aniskip")
local skipped_op, skipped_ed, skip_enabled = false, false, true
local function skip()
    if not skip_enabled then return end
    local t = mp.get_property_number("time-pos")
    if not t then return end
    local op_target = options.op_end - options.offset
    local ed_target = options.ed_end - options.offset
    if options.op_end > 0 and t >= options.op_start and t < op_target then
        if options.toggle or not skipped_op then
            mp.set_property_number("time-pos", op_target); skipped_op = true
        end
    end
    if options.ed_end > 0 and t >= options.ed_start and t < ed_target then
        if options.toggle or not skipped_ed then
            mp.set_property_number("time-pos", ed_target); skipped_ed = true
        end
    end
end
local function toggle_skip()
    skip_enabled = not skip_enabled
    if skip_enabled then skipped_op, skipped_ed = false, false end
    mp.osd_message("Skip: " .. (skip_enabled and "ON" or "OFF"), 2)
end
if options.toggle then mp.add_key_binding(options.toggle_key, "toggle-skip", toggle_skip) end
mp.observe_property("time-pos", "number", skip)
SKIP_LUA
}

# resolve a MAL id from a title via Jikan (used only for --skip-title text override)
jikan_mal_id() {
    curl -s --connect-timeout 8 -A "$agent" \
        "https://api.jikan.moe/v4/anime?q=$(printf '%s' "$1" | sed 's/ /%20/g')&limit=1" |
        sed -nE 's|.*"mal_id":([0-9]+).*|\1|p' | head -1
}

# MAL id for the current anime: explicit override, else from the cached play page
get_mal_id() {
    if [ -n "$mal_id" ]; then
        printf '%s' "$mal_id"
        return 0
    fi
    printf '%s' "$cached_play_html" | grep -oE 'myanimelist\.net/anime/[0-9]+' | head -1 | grep -oE '[0-9]+'
}

# builds the mpv --script-opts flag with OP/ED skip times for the current episode
get_skip_flag() {
    _mal="$(get_mal_id)"
    [ -z "$_mal" ] && printf "\033[1;33m%s\033[0m\n" "ani-skip: MAL id not found for this anime" 1>&2 && return 0
    _meta="$(curl -s --connect-timeout 8 -A "$agent" "https://api.aniskip.com/v1/skip-times/${_mal}/${ep_no}?types=op&types=ed")"
    printf '%s' "$_meta" | grep -q '"found":true' || { printf "\033[1;33m%s\033[0m\n" "ani-skip: no skip times for episode ${ep_no}" 1>&2 && return 0; }
    _opts=""
    for _t in op ed; do
        _seg="$(printf '%s' "$_meta" | grep -Eo '"start_time":[0-9.]+,"end_time":[0-9.]+},"skip_type":"'"$_t"'"')"
        [ -z "$_seg" ] && continue
        _st="$(printf '%s' "$_seg" | sed -nE 's|"start_time":([0-9.]+).*|\1|p')"
        _en="$(printf '%s' "$_seg" | sed -nE 's|.*"end_time":([0-9.]+)}.*|\1|p')"
        [ -n "$_opts" ] && _opts="$_opts,"
        _opts="${_opts}aniskip-${_t}_start=${_st},aniskip-${_t}_end=${_en}"
    done
    [ -z "$_opts" ] && return 0
    install_skip_lua || { printf "\033[1;33m%s\033[0m\n" "ani-skip: could not install mpv lua plugin" 1>&2 && return 0; }
    printf -- "--script-opts=%s" "$_opts"
}

# search the query and give results
search_anime() {
    # scrape animeworld search results: <div class="item"> ... <a href="/play/<slug>" ... class="name">Title</a>
    # mode=dub -> only DUB-badged entries; otherwise -> only non-DUB (sub ITA) entries
    curl -s -A "$agent" "https://${animeworld_base}/search?keyword=$1" | tr '\n' ' ' |
        sed 's|<div class="item">|\n|g' | while IFS= read -r item; do
        printf '%s' "$item" | grep -q 'class="name"' || continue
        dub=""
        printf '%s' "$item" | grep -q '<div class="dub">' && dub=" (DUB)"
        case "$mode" in
            dub) [ -n "$dub" ] || continue ;;
            *) [ -z "$dub" ] || continue ;;
        esac
        slug="$(printf '%s' "$item" | sed -nE 's|.*<a href="/play/([^"]*)" data-jtitle="[^"]*" class="name">.*|\1|p')"
        name="$(printf '%s' "$item" | sed -nE 's|.*class="name">([^<]*)</a>.*|\1|p' |
            sed 's|&amp;|\&|g;s|&#0*39;|'\''|g;s|&#x27;|'\''|g;s|&quot;|"|g;s|&#0*34;|"|g;s|&lt;|<|g;s|&gt;|>|g')"
        [ -n "$slug" ] && printf '%s\t%s%s\n' "$slug" "$name" "$dub"
    done | awk -F'\t' '!seen[$1]++'
}

time_until_next_ep() {
    animeschedule="https://animeschedule.net"
    query="$(printf "%s\n" "$*" | tr ' ' '+')"
    curl -s -G "$animeschedule/api/v3/anime" --data "q=${query}" | sed 's|"id"|\n|g' | sed -nE 's|.*,"route":"([^"]*)","premier.*|\1|p' | while read -r anime; do
        data=$(curl -s "$animeschedule/anime/$anime" | sed '1,/"anime-header-list-buttons-wrapper"/d' | sed -nE 's|.*countdown-time-raw" datetime="([^"]*)">.*|Next Raw Release: \1|p;s|.*countdown-time" datetime="([^"]*)">.*|Next Sub Release: \1|p;s|.*english-title">([^<]*)<.*|English Title: \1|p;s|.*main-title".*>([^<]*)<.*|Japanese Title: \1|p')
        status="Ongoing"
        color="33"
        printf "%s\n" "$data"
        ! (printf "%s\n" "$data" | grep -q "Next Raw Release:") && status="Finished" && color="32"
        printf "Status:  \033[1;%sm%s\033[0m\n---\n" "$color" "$status"
    done
    exit 0
}

# get the episodes list of the selected anime
episodes_list() {
    # fetch play page (follows redirect to /play/<slug>/<epId>) and list episode numbers
    curl -sL -A "$agent" "https://${animeworld_base}/play/$*" |
        grep -oE 'data-episode-num="[0-9]+"' | grep -oE '[0-9]+' | sort -n -u
}

# PLAYING

process_hist_entry() {
    ep_list=$(episodes_list "$id")
    latest_ep=$(printf "%s\n" "$ep_list" | tail -n1)
    title=$(printf "%s\n" "$title" | sed "s|[0-9]\+ episodes|${latest_ep} episodes|")
    ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
    [ -n "$ep_no" ] && printf "%s\t%s - episode %s\n" "$id" "$title" "$ep_no"
}

update_history() {
    if grep -q -- "$id" "$histfile"; then
        sed -E "s|^[^	]+	${id}	[^	]+$|${ep_no}	${id}	${title}|" "$histfile" >"${histfile}.new"
    else
        cp "$histfile" "${histfile}.new"
        printf "%s\t%s\t%s\n" "$ep_no" "$id" "$title" >>"${histfile}.new"
    fi
    mv "${histfile}.new" "$histfile"
}

download() {
    # animeworld serves direct mp4 files; no referrer needed
    # shellcheck disable=SC2086
    aria2c --enable-rpc=false --check-certificate=false --continue $iSH_DownFix --summary-interval=0 -x 16 -s 16 "$1" --dir="$download_dir" -o "$2.mp4" --download-result=hide
}

android_mpv() {
    dir="/storage/emulated/0/mpv"
    file="$dir/mpv.config.mp4"
    if [ -w "${dir%*/mpv}" ]; then
        [ -d "${dir}" ] || mkdir "${dir}"
        printf "%s" "$3" | sed 's| --|\n|g; s|^--||g' >"$file"
    fi
    am start --user 0 -a android.intent.action.VIEW -d "$1" -n is.xyz.mpv/.MPVActivity -e "title" "$2" >/dev/null 2>&1
    unset dir file
}

play_episode() {
    [ "$log_episode" = 1 ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && command -v logger >/dev/null && logger -t ani-cli "${anime_title}${ep_no}"
    [ -z "$episode" ] && get_episode_url
    [ "$skip_intro" = 1 ] && skip_flag="$(get_skip_flag)"
    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf "All links:\n%s\nSelected link:\n" "$links"
            printf "%s\n" "$episode"
            ;;
        mpv*)
            if [ "$no_detach" = 0 ]; then
                nohup $player_function $skip_flag --tls-verify=no --force-media-title="${anime_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 &
            else
                $player_function $skip_flag $refr_flag --tls-verify=no --force-media-title="${anime_title}Episode ${ep_no}" "$episode"
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        android_mpv) "$player_function" "$episode" "${anime_title}Episode ${ep_no}" "--tls-verify=no $refr_flag" 2>&1 & ;;
        android_vlc) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "${anime_title}Episode ${ep_no}" >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                # omit --keep-running when an IINA instance exists to prevent hanging
                nohup $player_function --no-stdin --mpv-tls-verify=no --mpv-force-media-title="${anime_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --mpv-tls-verify=no --keep-running --mpv-force-media-title="${anime_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            fi
            ;;
        flatpak_mpv) flatpak run io.mpv.Mpv --tls-verify=no --force-media-title="${anime_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 & ;;
        vlc*) nohup $player_function --http-referrer="${refr_flag#--referrer=}" --play-and-exit --meta-title="${anime_title}Episode ${ep_no}" "$episode" >/dev/null 2>&1 & ;;
        *yncpla*) nohup $player_function "$episode" -- --tls-verify=no --force-media-title="${anime_title}Episode ${ep_no}" $refr_flag >/dev/null 2>&1 & ;;
        download) "$player_function" "$episode" "${anime_title}Episode ${ep_no}" ;;
        catt) nohup catt cast "$episode" >/dev/null 2>&1 & ;;
        iSH)
            printf "\e]8;;vlc://%s\a~~~~~~~~~~~~~~~~~~~~\n~ Tap to open VLC ~\n~~~~~~~~~~~~~~~~~~~~\e]8;;\a\n" "$episode"
            sleep 5
            ;;
        *) nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac
    replay="$episode"
    unset episode
    update_history
    [ "$use_external_menu" = "1" ] && wait
    [ "$use_external_menu" = "2" ] && wait
}

play() {
    start=$(printf "%s" "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    end=$(printf "%s" "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$start" = "-1" ] && ep_no=$(printf "%s" "$ep_list" | tail -n1) && unset start
    [ -z "$end" ] || [ "$end" = "$start" ] && unset start end
    [ "$end" = "-1" ] && end=$(printf "%s" "$ep_list" | tail -n1)
    line_count=$(printf "%s\n" "$ep_no" | wc -l | tr -d "[:space:]")
    if [ "$line_count" != 1 ] || [ -n "$start" ]; then
        [ -z "$start" ] && start=$(printf "%s\n" "$ep_no" | head -n1)
        [ -z "$end" ] && end=$(printf "%s\n" "$ep_no" | tail -n1)
        range=$(printf "%s\n" "$ep_list" | sed -nE "/^${start}\$/,/^${end}\$/p")
        [ -z "$range" ] && die "Invalid range!"
        for i in $range; do
            tput clear
            ep_no=$i
            printf "\33[2K\r\033[1;34mPlaying episode %s...\033[0m\n" "$ep_no"
            [ "$i" = "$end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    # moves up to stored position and deletes to end
    [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && tput rc && tput ed
}

# MAIN

# setup
agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:150.0) Gecko/20100101 Firefox/150.0"
animeworld_base="www.animeworld.tv"
mode="${ANI_CLI_MODE:-sub}"
download_dir="${ANI_CLI_DOWNLOAD_DIR:-.}"
log_episode="${ANI_CLI_LOG:-1}"
quality="${ANI_CLI_QUALITY:-best}"
case "$(uname -a | cut -d " " -f 1,3-)" in
    *Darwin*) player_function="${ANI_CLI_PLAYER:-$(where_iina)}" ;;   # mac OS
    *ndroid*) player_function="${ANI_CLI_PLAYER:-android_mpv}" ;;     # Android OS (termux)
    *MINGW* | *WSL2*) player_function="${ANI_CLI_PLAYER:-mpv.exe}" ;; # Windows OS
    *ish*) player_function="${ANI_CLI_PLAYER:-iSH}" ;;                # iOS (iSH)
    *) player_function="${ANI_CLI_PLAYER:-$(where_mpv)}" ;;           # Linux OS
esac

no_detach="${ANI_CLI_NO_DETACH:-0}"
exit_after_play="${ANI_CLI_EXIT_AFTER_PLAY:-0}"
use_external_menu="${ANI_CLI_EXTERNAL_MENU:-0}"
external_menu_normal_window="${ANI_CLI_EXTERNAL_MENU_NORMAL_WINDOW:-0}"
skip_intro="${ANI_CLI_SKIP_INTRO:-0}"
skip_title="${ANI_CLI_SKIP_TITLE:-}"
[ -t 0 ] || (command -v dmenu && use_external_menu=2)
[ -t 0 ] || (command -v rofi && use_external_menu=1)
hist_dir="${ANI_CLI_HIST_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/ani-cli}"
[ ! -d "$hist_dir" ] && mkdir -p "$hist_dir"
histfile="$hist_dir/ani-hsts"
[ ! -f "$histfile" ] && : >"$histfile"
search="${ANI_CLI_DEFAULT_SOURCE:-scrape}"
branch="${ANI_CLI_BRANCH:-master}"
update_check="${ANI_CLI_UPDATE_CHECK:-1}"

while [ $# -gt 0 ]; do
    case "$1" in
        -v | --vlc)
            case "$(uname -a | cut -d " " -f 1,3-)" in
                *ndroid*) player_function="android_vlc" ;;
                MINGW* | *WSL2*) player_function="vlc.exe" ;;
                *ish*) player_function="iSH" ;;
                *) player_function="vlc" ;;
            esac
            ;;
        -s | --syncplay)
            case "$(uname -s)" in
                Darwin*) player_function="/Applications/Syncplay.app/Contents/MacOS/syncplay" ;;
                MINGW* | *Msys)
                    export PATH="$PATH":"/c/Program Files (x86)/Syncplay/"
                    player_function="syncplay.exe"
                    ;;
                *) player_function="syncplay" ;;
            esac
            ;;
        -q | --quality)
            [ $# -lt 2 ] && die "missing argument!"
            quality="$2"
            shift
            ;;
        -S | --select-nth)
            [ $# -lt 2 ] && die "missing argument!"
            index="$2"
            shift
            ;;
        -c | --continue) search=history ;;
        -d | --download)
            [ "$player_function" = "iSH" ] && iSH_DownFix="--async-dns=false"
            player_function=download
            ;;
        -D | --delete)
            : >"$histfile"
            exit 0
            ;;
        -l | --logview)
            case "$(uname -s)" in
                Darwin*) log show --predicate 'process == "logger"' ;;
                Linux*) journalctl -t ani-cli ;;
                *) die "Logger not implemented for your platform" ;;
            esac
            exit 0
            ;;
        -V | --version) version_info ;;
        -h | --help) help_info ;;
        -e | --episode | -r | --range)
            [ $# -lt 2 ] && die "missing argument!"
            ep_no="$2"
            shift
            ;;
        --dub) mode="dub" ;;
        --no-detach) no_detach=1 ;;
        --exit-after-play) exit_after_play=1 && no_detach=1 ;;
        --rofi) use_external_menu=1 ;;
        --dmenu) use_external_menu=2 ;;
        --skip) skip_intro=1 ;;
        --skip-title)
            [ $# -lt 2 ] && die "missing argument!"
            skip_title="$2"
            shift
            ;;
        -N | --nextep-countdown) search=nextep ;;
        -U | --update)
            branch="${2:-$branch}"
            update_script
            ;;
        *) query="$(printf "%s" "$query $1" | sed "s|^ ||;s| |+|g")" ;;
    esac
    shift
done
[ "$use_external_menu" = "0" ] && multi_selection_flag="${ANI_CLI_MULTI_SELECTION:-"-m"}"
[ "$use_external_menu" = "1" ] && multi_selection_flag="${ANI_CLI_MULTI_SELECTION:-"-multi-select"}"
[ "$external_menu_normal_window" = "1" ] && external_menu_args="-normal-window"
printf "\33[2K\r\033[1;34mChecking dependencies...\033[0m\n"
dep_ch "curl" "sed" "grep" || true
# openssl no longer required (animeworld serves direct mp4)
dep_ch "fzf" || true
case "$player_function" in
    debug) ;;
    download) dep_ch "aria2c" ;;
    android*) printf "\33[2K\rChecking of players on Android is disabled.\nANI-CLI recommends Android MPV for full compatibility.\nAdd:\n include='/storage/emulated/0/mpv/mpv.config.mp4'\nto:\n MPV > Settings > Advanced > mpv.conf\nfor full functionality.\nIgnore, If Done.\n" ;;
    *iSH*) printf "\33[2K\rChecking of players on iOS is disabled\n" ;;
    flatpak_mpv) true ;; # handled out of band in where_mpv
    *) dep_ch "$player_function" ;;
esac

# notify (from cache) if a newer version is available on the fork
check_update_notice

# idk where to put this, so I put it here...
trap 'cleanup; exit 1' INT HUP

# searching
case "$search" in
    history)
        anime_list=$(while read -r ep_no id title; do process_hist_entry & done <"$histfile")
        wait
        [ -z "$anime_list" ] && die "No unwatched series in history!"
        [ -z "${index##*[!0-9]*}" ] && id=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime: " | cut -f1)
        [ -z "${index##*[!0-9]*}" ] || id=$(printf "%s" "$anime_list" | sed -n "${index}p" | cut -f1)
        [ -z "$id" ] && exit 1
        title=$(printf "%s" "$anime_list" | grep "$id" | cut -f2 | sed 's/ - episode.*//')
        ep_list=$(episodes_list "$id")
        ep_no=$(printf "%s" "$anime_list" | grep "$id" | cut -f2 | sed -nE 's/.*- episode (.+)$/\1/p')
        anime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ;;
    *)
        if [ "$use_external_menu" = "0" ]; then
            while [ -z "$query" ]; do
                printf "\33[2K\r\033[1;36mSearch anime: \033[0m" && read -r query
            done
        else
            [ -z "$query" ] && query=$(printf "" | external_menu "" "Search anime: " "$external_menu_args")
            [ -z "$query" ] && exit 1
        fi
        # for checking new releases by specifying anime name
        [ "$search" = "nextep" ] && time_until_next_ep "$query"

        query=$(printf "%s" "$query" | sed "s| |+|g")
        anime_list=$(search_anime "$query")
        [ -z "$anime_list" ] && die "No results found!"
        [ "$index" -eq "$index" ] 2>/dev/null && result=$(printf "%s" "$anime_list" | sed -n "${index}p")
        [ -z "$index" ] && result=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime: ")
        [ -z "$result" ] && exit 1
        title=$(printf "%s" "$result" | cut -f2)
        anime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        id=$(printf "%s" "$result" | cut -f1)
        ep_list=$(episodes_list "$id")
        [ -z "$ep_no" ] && ep_no=$(printf "%s" "$ep_list" | nth "Select episode: " "$multi_selection_flag")
        [ -z "$ep_no" ] && exit 1
        ;;
esac
# resolve an explicit --skip-title override (numeric = MAL id, text = Jikan search); otherwise the MAL id is read from the anime page later
if [ "$skip_intro" = 1 ] && [ -n "$skip_title" ]; then
    case "$skip_title" in
        *[!0-9]*) mal_id="$(jikan_mal_id "$skip_title")" ;;
        *) mal_id="$skip_title" ;;
    esac
fi

# moves the cursor up one line and clears that line
tput cuu1 && tput el
# stores the position of cursor
tput sc

# playback & loop
play
[ "$player_function" = "download" ] || [ "$player_function" = "debug" ] && exit 0

while cmd=$(printf "next\nreplay\nprevious\nselect\nquit" | nth "Playing episode $ep_no of $title... "); do
    case "$cmd" in
        next) ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null ;;
        replay) episode="$replay" ;;
        previous) ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{g;1!p;};h") 2>/dev/null ;;
        select) ep_no=$(printf "%s" "$ep_list" | nth "Select episode: " "$multi_selection_flag") ;;
        *)
            cleanup
            exit 0
            ;;
    esac
    [ -z "$ep_no" ] && die "Out of range"
    play
done

