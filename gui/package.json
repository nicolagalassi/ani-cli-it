{
  "name": "aniplay-it",
  "version": "0.2.0",
  "description": "GUI italiana per ani-cli-it — anime Sub/Dub ITA da AnimeWorld",
  "author": "nicolagalassi",
  "license": "GPL-3.0",
  "repository": "https://github.com/nicolagalassi/ani-cli-it",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k -n vite,electron \"npm:dev:vite\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder --linux AppImage --publish never",
    "dist:win": "vite build && electron-builder --win --publish never",
    "dist:mac": "vite build && electron-builder --mac --publish never",
    "dist:all": "vite build && electron-builder -mwl --publish never",
    "dist:dir": "vite build && electron-builder --dir --publish never"
  },
  "build": {
    "appId": "com.nicolagalassi.aniplayit",
    "productName": "AniPlay ITA",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["dist/**", "electron/**", "package.json"],
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo",
      "icon": "build/icon.png",
      "artifactName": "AniPlay-ITA-${version}.${ext}"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png",
      "artifactName": "AniPlay-ITA-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "AniPlay-ITA-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }, { "target": "zip", "arch": ["x64", "arm64"] }],
      "icon": "build/icon.png",
      "category": "public.app-category.entertainment",
      "artifactName": "AniPlay-ITA-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "wait-on": "^8.0.1"
  }
}
